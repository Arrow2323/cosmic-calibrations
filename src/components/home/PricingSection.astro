---
import { PRICING } from "@/utils/constants";
---

<!--
  Pricing — two cards: Single Session + 10-Series Package (highlighted).
  Mined from existing site. Clean and transparent.
-->
<section id="pricing" class="py-24 md:py-32 px-6 bg-brand-paper">
  <div class="max-w-4xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="section-label mb-4">Investment</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal mb-4">
        Transparent pricing, no surprises
      </h2>
      <p class="text-lg text-brand-charcoal/60 max-w-2xl mx-auto leading-relaxed">
        Every session is hands-on, one-on-one, and tailored to your structure.
        We respond to all inquiries within 24 hours.
      </p>
    </div>

    <!-- Two cards -->
    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      <!-- Single Session -->
      <div class="rounded-[20px] border border-brand-teal/10 bg-white p-8 flex flex-col gap-4">
        <p class="text-xs font-bold uppercase tracking-[0.15em] text-brand-grey">
          Single Session
        </p>
        <div>
          <span class="text-4xl font-heading font-black text-brand-teal">${PRICING.singleSession}</span>
          <span class="text-brand-charcoal/50 text-sm ml-1">/ session</span>
        </div>
        <p class="text-sm text-brand-charcoal/60 leading-relaxed">
          {PRICING.sessionDuration} of one-on-one hands-on Structural Integration.
          Includes postural assessment and take-home movement guidance.
        </p>
      </div>

      <!-- 10-Series (highlighted) -->
      <div class="rounded-[20px] border-2 border-brand-teal bg-brand-teal/5 p-8 flex flex-col gap-4 relative">
        <div class="absolute -top-3 right-6 bg-brand-teal text-white text-[10px] font-bold uppercase tracking-[0.2em] px-3 py-1 rounded-full">
          Best Value
        </div>
        <p class="text-xs font-bold uppercase tracking-[0.15em] text-brand-grey">
          10-Series Package
        </p>
        <div>
          <span class="text-4xl font-heading font-black text-brand-teal">${PRICING.tenSeries.toLocaleString()}</span>
          <span class="text-brand-charcoal/50 text-sm ml-1">/ series</span>
        </div>
        <p class="text-sm text-brand-charcoal/60 leading-relaxed">
          All ten sessions of the protocol. Each builds on the last for
          systematic, lasting structural change. Save ${PRICING.savings} vs. individual sessions.
        </p>
      </div>
    </div>

    <p class="text-center text-xs text-brand-charcoal/40 mt-8">
      Payment plans available. Package sessions never expire. Same rate for in-person and virtual consultation.
    </p>
    <p class="text-center text-xs text-brand-charcoal/40 mt-2">
      <a href="/faq" class="text-brand-teal hover:underline font-medium">Gift certificates</a> available — individual sessions or full series. <a href="/faq" class="text-brand-teal hover:underline font-medium">HSA/FSA</a> accepted with proper documentation.
    </p>
  </div>
</section>
