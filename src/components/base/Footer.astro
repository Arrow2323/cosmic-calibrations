---
import { BUSINESS, NAV, SOCIAL } from "@/utils/constants";
---

<footer class="bg-brand-teal text-white py-16 px-6 border-t border-white/10">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between gap-10">
      <!-- Brand + Contact -->
      <div class="max-w-xs">
        <h3 class="text-xl font-heading font-bold mb-2">{BUSINESS.name}</h3>
        <p class="text-sm text-brand-grey mb-4">
          {BUSINESS.tagline}
        </p>
        <p class="text-sm text-white/50 mb-1">{BUSINESS.location}</p>
        <a
          href={`mailto:${BUSINESS.email}`}
          class="text-sm text-brand-grey hover:text-white transition-colors"
        >
          {BUSINESS.email}
        </a>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-col gap-3">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-grey mb-1">Navigate</p>
        <a href="/" class="text-sm text-white/60 hover:text-white transition-colors">Home</a>
        {NAV.main.map((link) => (
          <a
            href={link.href}
            class="text-sm text-white/60 hover:text-white transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a href="/contact" class="text-sm text-white/60 hover:text-white transition-colors">Contact</a>
      </div>

      <!-- Legal -->
      <div class="flex flex-col gap-3">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-grey mb-1">Legal</p>
        <a href="/privacy" class="text-sm text-white/60 hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="text-sm text-white/60 hover:text-white transition-colors">Terms of Service</a>
        <a href="/blog" class="text-sm text-white/60 hover:text-white transition-colors">Blog</a>
        <a href="/testimonials" class="text-sm text-white/60 hover:text-white transition-colors">Testimonials</a>
      </div>

      <!-- Connect -->
      <div class="flex flex-col gap-3">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-grey mb-1">Connect</p>
        {SOCIAL.googleBusiness && SOCIAL.googleBusiness !== "https://g.page/r/PLACEHOLDER" ? (
          <a href={SOCIAL.googleBusiness} target="_blank" rel="noopener" class="text-sm text-white/60 hover:text-white transition-colors">Google Business Profile</a>
        ) : (
          <span class="text-sm text-white/30">Google Business — coming soon</span>
        )}
        {SOCIAL.instagram ? (
          <a href={SOCIAL.instagram} target="_blank" rel="noopener" class="text-sm text-white/60 hover:text-white transition-colors">Instagram</a>
        ) : (
          <span class="text-sm text-white/30">Instagram — coming soon</span>
        )}
        {SOCIAL.facebook ? (
          <a href={SOCIAL.facebook} target="_blank" rel="noopener" class="text-sm text-white/60 hover:text-white transition-colors">Facebook</a>
        ) : (
          <span class="text-sm text-white/30">Facebook — coming soon</span>
        )}
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/30">
        &copy; {new Date().getFullYear()} {BUSINESS.name}. All rights reserved.
      </p>
      <p class="text-xs text-white/20 italic">
        Recalibrate your physical existence.
      </p>
    </div>
  </div>
</footer>
