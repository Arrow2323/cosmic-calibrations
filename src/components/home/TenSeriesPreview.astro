---
import { getCollection } from "astro:content";

const sessions = await getCollection("sessions");
const sorted = sessions.sort((a, b) => a.data.num - b.data.num);
---

<!--
  10-Series Preview — Interactive grid.
  Cards expand to show description on click (handled via minimal JS).
  Number + title always visible; focus + desc revealed on interaction.
-->
<section id="ten-series" class="py-24 md:py-32 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="section-label mb-4">The Protocol</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal mb-4">
        The 10-Series Recovery Protocol
      </h2>
      <p class="text-lg text-brand-charcoal/60 max-w-2xl mx-auto leading-relaxed">
        A systematic journey through your body's architecture. Each stage builds
        upon the last — methodically releasing chronic tension and integrating
        your structure. Tap any tile to learn what happens in that session.
      </p>
    </div>

    <!-- Session Grid — 5-column on desktop, 2 on mobile -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 md:gap-4">
      {sorted.map((session) => (
        <div
          class="session-tile group cursor-pointer rounded-[18px] border border-brand-teal/10 bg-white p-4 md:p-5 transition-all duration-300 hover:border-brand-teal/30 hover:shadow-sm flex flex-col gap-3 card-lift reveal"
          data-session={String(session.data.num)}
        >
          <!-- Number -->
          <div class="flex items-center justify-between">
            <span
              class="text-3xl font-black text-brand-grey/20 group-hover:text-brand-teal/15 transition-colors"
            >
              {String(session.data.num).padStart(2, "0")}
            </span>
            <div class="w-2 h-2 rounded-full bg-brand-teal/20 group-hover:bg-brand-teal/50 transition-colors"></div>
          </div>

          <!-- Title + Focus -->
          <div>
            <h4 class="font-heading font-bold text-sm leading-tight text-brand-teal">
              {session.data.title}
            </h4>
            <p class="text-[10px] font-bold uppercase tracking-widest mt-1 text-brand-grey">
              {session.data.focus}
            </p>
          </div>

          <!-- Description — always visible on mobile, hover on desktop -->
          <p class="text-xs leading-relaxed text-brand-charcoal/60 group-hover:text-brand-charcoal/80 transition-colors mt-auto pt-2 border-t border-brand-teal/5">
            {session.data.desc}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA to full services page -->
    <div class="text-center mt-12">
      <a
        href="/services"
        class="inline-flex items-center gap-2 text-brand-teal font-semibold text-sm hover:gap-3 transition-all"
      >
        View full series details
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>
