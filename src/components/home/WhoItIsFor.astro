---
const audiences = [
  {
    title: "Desk-Bound Professionals",
    subtitle: "You spend 8+ hours shaping your fascia into a C-curve",
    body: "Tech Neck. Anterior Pelvic Tilt. The slouched thoracolumbar pattern that keeps you in chronic tension. We reverse the structural damage of sitting — session by session, layer by layer.",
    outcome: "Sit through meetings without noticing your body.",
  },
  {
    title: "Post-Surgical Recovery",
    subtitle: "Surgery leaves internal scar tissue that limits your range",
    body: "Adhesions between tissue layers restrict movement long after the incision heals. Our systematic bodywork restores glide between fascial planes — precisely, methodically, permanently.",
    outcome: "Move freely again, without compensation patterns.",
  },
  {
    title: "Active Bodies Seeking Ease",
    subtitle: "You move well, but something still feels off",
    body: "Athletes, yogis, dancers, and weekend warriors often discover that certain restrictions won't resolve through exercise alone. SI addresses the underlying fascial organization that no amount of stretching can reach.",
    outcome: "Find the ease and range you know should be there.",
  },
];
---

<!--
  Who It's For — 3 editorial audience cards.
  Photo-driven layout, not icon-cards. Clean serif headings.
  Each card has: title, subtitle (problem), body (solution), outcome.
-->
<section class="py-24 md:py-32 px-6 bg-brand-paper">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-16">
      <p class="section-label mb-4">Who It's For</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal mb-4">
        Your body is telling you something
      </h2>
      <p class="text-lg text-brand-charcoal/60 max-w-2xl">
        Structural Integration helps when conventional approaches — massage, stretching,
        exercise — have hit their limit.
      </p>
    </div>

    <!-- Audience Cards — bento grid: first card spans full width, two below -->
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8 stagger-children">
      {audiences.map((item, i) => (
        <div class={`flex flex-col gap-4 bg-white rounded-[24px] border border-brand-teal/10 p-8 card-lift ${i === 0 ? 'md:col-span-2 lg:grid lg:grid-cols-2 lg:gap-10 lg:items-center' : ''}`}>
          <div class={i === 0 ? 'space-y-4' : 'space-y-4'}>
            <h3 class="text-xl font-heading font-bold text-brand-teal leading-tight">
              {item.title}
            </h3>

            <p class="text-sm text-brand-grey font-semibold uppercase tracking-[0.08em] leading-snug">
              {item.subtitle}
            </p>

            <p class="text-brand-charcoal/70 leading-relaxed text-sm">
              {item.body}
            </p>

            <!-- Outcome -->
            <div class="mt-auto pt-4 border-t border-brand-teal/10">
              <p class="text-xs text-brand-grey uppercase tracking-[0.12em] font-bold mb-1">
                The Result
              </p>
              <p class="text-sm text-brand-teal font-heading italic font-semibold">
                "{item.outcome}"
              </p>
            </div>
          </div>
          {i === 0 && (
            <div class="hidden lg:flex items-center justify-center">
              <div class="w-32 h-32 rounded-full bg-brand-teal/5 flex items-center justify-center">
                <span class="text-5xl font-heading font-black text-brand-teal/20">SI</span>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
