---
import "@/styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import SEO from "./SEO.astro";
import type { Props as SEOProps } from "./SEO.astro";

export interface Props {
  seo?: SEOProps;
  containerClass?: string;
}

const { seo = {}, containerClass = "" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO {...seo} />
  </head>
  <body class="min-h-screen flex flex-col bg-brand-paper text-brand-charcoal font-body antialiased">
    <Header />
    <main class={`flex-1 ${containerClass}`}>
      <slot />
    </main>
    <Footer />
    <!-- Scroll reveal observer — zero-dependency, ~300 bytes -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("visible"); observer.unobserve(e.target); } });
      }, { threshold: 0.15, rootMargin: "0px 0px -40px 0px" });
      document.querySelectorAll(".reveal").forEach(el => observer.observe(el));
    </script>
  </body>
</html>
