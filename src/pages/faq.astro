---
import Layout from "@/components/base/Layout.astro";
import Accordion from "@/components/ui/Accordion.astro";
import faqData from "@/data/faq.json";
---

<Layout seo={{ title: "Frequently Asked Questions" }}>
  <section class="pt-28 pb-24 px-6 bg-white">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="mb-16">
        <p class="section-label mb-4">Common Questions</p>
        <h1 class="text-4xl md:text-5xl font-heading font-bold text-brand-teal">
          Frequently Asked Questions
        </h1>
      </div>

      <!-- General FAQs -->
      <Accordion items={faqData.general} />

      <!-- Credential Section -->
      <div class="mt-24 mb-12">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-teal">
          About the Credential
        </h2>
      </div>
      <Accordion items={faqData.credentials} />

      <!-- Still have questions? -->
      <div class="mt-16 pt-8 border-t border-brand-teal/10 text-center">
        <p class="text-brand-charcoal/60 mb-4">Still have questions?</p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 text-brand-teal font-semibold hover:underline underline-offset-4"
        >
          Get in touch
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
