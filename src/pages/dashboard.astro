    modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
    modal.innerHTML = `
      <div class="bg-white rounded-[24px] max-w-3xl w-full p-8 shadow-2xl mb-10" onclick="event.stopPropagation()">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h3 class="text-2xl font-heading font-bold text-brand-teal">${client.name} — SI Guide</h3>
            <p class="text-xs text-brand-grey">${si.client_summary?.substring(0, 120) || ""}...</p>
