          <button class="text-brand-grey hover:text-brand-charcoal text-xl leading-none" onclick="this.closest('.fixed').remove()">&times;</button>
        </div>
        ${si.contraindications?.length ? `<div class="p-3 rounded-xl bg-amber-50 border border-amber-200 mb-4"><p class="text-xs font-bold text-amber-700 mb-1">Contraindications</p>${si.contraindications.map((c: string) => `<p class="text-xs text-amber-600">${c}</p>`).join("")}</div>` : ""}
        <div class="space-y-2 max-h-[60vh] overflow-y-auto">
          ${si.session_plan?.map((s: any) => `
            <details class="group">
              <summary class="cursor-pointer flex items-center justify-between p-3 rounded-xl bg-brand-paper hover:bg-brand-teal/5 transition-colors">
                <span class="text-sm font-semibold text-brand-teal">${s.session}. ${s.rolfing_focus}</span>
                <span class="text-xs text-brand-grey">${s.armor_priority?.length || 0} armor · ${s.gene_keys_somatic_shadows?.length || 0} shadows</span>
              </summary>
              <div class="mt-2 p-4 space-y-2 text-sm">
                <p><strong class="text-brand-teal">Pacing:</strong> ${s.pacing}</p>
                ${s.armor_priority?.length ? `<div><strong class="text-brand-teal">Armor:</strong> ${s.armor_priority.map((a: any) => `<span class="inline-block text-xs mr-1 px-2 py-0.5 rounded-full ${a.status.includes('ARMORED') ? 'bg-amber-100 text-amber-700' : 'bg-green-50 text-green-700'}">${a.segment}</span>`).join(" ")}</div>` : ""}
                ${s.emotional_release_potential ? `<p class="text-brand-charcoal/70"><strong class="text-brand-teal">Emotional:</strong> ${s.emotional_release_potential}</p>` : ""}
              </div>
            </details>
          `).join("") || "<p class='text-sm text-brand-charcoal/40'>No session plan data</p>"}
        </div>
        <div class="mt-6 pt-4 border-t border-brand-teal/10 flex gap-3">
          <button class="text-sm font-semibold text-brand-teal hover:underline" onclick="window.print()">Print Guide</button>
          <button class="text-sm text-brand-grey hover:text-brand-charcoal" onclick="this.closest('.fixed').remove()">Close</button>
        </div>
      </div>`;
    document.body.appendChild(modal);
  }

  // ── Financial ──
  document.getElementById("fin-form")!.addEventListener("submit", (e) => {
    e.preventDefault();
    const fin = load("financial");
    fin.unshift({
      desc: (document.getElementById("fin-desc") as HTMLInputElement).value,
      amount: parseFloat((document.getElementById("fin-amount") as HTMLInputElement).value) || 0,
      type: (document.getElementById("fin-type") as HTMLSelectElement).value,
      date: new Date().toISOString().split("T")[0],
    });
    save("financial", fin);
    (document.getElementById("fin-form") as HTMLFormElement).reset();
    renderFinancial();
    refreshOverview();
  });

  function renderFinancial() {
    const fin = load("financial");
    const now = new Date();
    const mtd = fin.filter((t: any) => new Date(t.date).getMonth() === now.getMonth() && t.type === "income").reduce((s: number, t: any) => s + t.amount, 0);
    const ytd = fin.filter((t: any) => new Date(t.date).getFullYear() === now.getFullYear() && t.type === "income").reduce((s: number, t: any) => s + t.amount, 0);
    const outstanding = fin.filter((t: any) => t.type === "income").reduce((s: number, t: any) => s + t.amount, 0) - fin.filter((t: any) => t.type === "expense").reduce((s: number, t: any) => s + t.amount, 0);
    document.getElementById("fin-revenue-mtd")!.textContent = "$" + mtd.toLocaleString();
    document.getElementById("fin-revenue-ytd")!.textContent = "$" + ytd.toLocaleString();
    document.getElementById("fin-outstanding")!.textContent = "$" + outstanding.toLocaleString();

    const el = document.getElementById("fin-list")!;
    el.innerHTML = fin.length ? fin.slice(0, 20).map((t: any) => `
      <div class="flex items-center justify-between p-3 rounded-xl bg-brand-paper">
        <div><span class="text-sm font-semibold text-brand-charcoal">${t.desc}</span><span class="text-xs text-brand-grey ml-2">${t.date}</span></div>
        <span class="text-sm font-semibold ${t.type === 'income' ? 'text-green-600' : 'text-red-500'}">${t.type === 'income' ? '+' : '-'}$${t.amount}</span>
      </div>`).join("") : "<p class='text-sm text-brand-charcoal/40'>No transactions yet.</p>";
  }

  // ── Invoicing ──
  document.getElementById("invoice-form")!.addEventListener("submit", (e) => {
    e.preventDefault();
    const invoices = load("invoices");
    invoices.unshift({
      client: (document.getElementById("inv-client") as HTMLInputElement).value,
      amount: parseFloat((document.getElementById("inv-amount") as HTMLInputElement).value) || 0,
      due: (document.getElementById("inv-due") as HTMLInputElement).value,
      status: (document.getElementById("inv-status") as HTMLSelectElement).value,
      desc: (document.getElementById("inv-desc") as HTMLInputElement).value,
      link: (document.getElementById("inv-link") as HTMLInputElement).value,
      created: new Date().toISOString().split("T")[0],
      id: "INV-" + Date.now().toString(36).toUpperCase(),
    });
    save("invoices", invoices);
    (document.getElementById("invoice-form") as HTMLFormElement).reset();
    renderInvoices();
  });

  function renderInvoices() {
    const invoices = load("invoices");
    const el = document.getElementById("invoice-list")!;
    const totalOutstanding = invoices.filter((i: any) => i.status !== "paid").reduce((s: number, i: any) => s + i.amount, 0);
    el.innerHTML = invoices.length ? `
      <div class="col-span-2 mb-2 flex items-center justify-between">
        <p class="text-sm text-brand-charcoal/60">${invoices.length} invoice${invoices.length !== 1 ? 's' : ''} · <span class="text-red-500 font-semibold">$${totalOutstanding.toLocaleString()} outstanding</span></p>
      </div>
      ${invoices.map((inv: any) => `
        <div class="bg-white rounded-[20px] border border-brand-teal/10 p-5 shadow-sm">
          <div class="flex items-center justify-between mb-2">
            <div>
              <span class="text-xs text-brand-grey font-mono">${inv.id}</span>
              <h4 class="font-heading font-bold text-brand-teal">${inv.client}</h4>
            </div>
            <span class="text-xs font-bold px-3 py-1 rounded-full ${inv.status === 'paid' ? 'bg-green-100 text-green-700' : inv.status === 'sent' ? 'bg-blue-100 text-blue-700' : 'bg-brand-paper text-brand-grey'}">${inv.status}</span>
          </div>
          <p class="text-sm text-brand-charcoal/70 mb-1">${inv.desc || "No description"}</p>
          <div class="flex items-center justify-between text-sm">
            <span class="font-semibold text-brand-charcoal">$${inv.amount.toLocaleString()}</span>
            <span class="text-xs text-brand-charcoal/40">Due ${inv.due || "—"}</span>
          </div>
          <div class="flex items-center gap-2 mt-3 pt-3 border-t border-brand-teal/5">
            <select class="text-xs rounded-lg border border-brand-teal/10 px-2 py-1" onchange="const v=this.value;const invs=JSON.parse(localStorage.getItem('portal-invoices')||'[]');const idx=invs.findIndex((x)=>x.id==='${inv.id}');if(idx>-1){invs[idx].status=v;localStorage.setItem('portal-invoices',JSON.stringify(invs));renderInvoices();}">
              <option ${inv.status === 'draft' ? 'selected' : ''} value="draft">Draft</option>
              <option ${inv.status === 'sent' ? 'selected' : ''} value="sent">Sent</option>
              <option ${inv.status === 'paid' ? 'selected' : ''} value="paid">Paid</option>
            </select>
            ${inv.link ? `<a href="${inv.link}" target="_blank" class="text-xs font-semibold text-brand-teal hover:underline">Pay with Stripe →</a>` : `<span class="text-xs text-brand-grey/50">No payment link</span>`}
            <button class="text-xs text-red-400 hover:text-red-600 ml-auto" onclick="event.stopPropagation();const invs=JSON.parse(localStorage.getItem('portal-invoices')||'[]');const i=invs.findIndex((x)=>x.id==='${inv.id}');if(i>-1){invs.splice(i,1);localStorage.setItem('portal-invoices',JSON.stringify(invs));renderInvoices();}">Delete</button>
          </div>
        </div>
      `).join("")}
    ` : "<p class='text-sm text-brand-charcoal/40 col-span-2'>No invoices yet. Create one to start billing clients.</p>";
  }
</script>
