---
import { CALENDLY } from "@/utils/constants";

export interface Props {
  /** Heading text above the widget */
  title?: string;
  /** Subtitle or description */
  subtitle?: string;
  /** Extra container classes */
  class?: string;
}

const {
  title = "Schedule a Session",
  subtitle = "Choose a time that works for you. Your session will be confirmed instantly and Rhonda's calendar will be updated automatically.",
  class: extraClass = "",
} = Astro.props;

const calendlyUrl = `https://calendly.com/${CALENDLY.username}/${CALENDLY.eventType}`;
const widgetId = "calendly-inline-widget";
---

<!--
  Calendly Inline Embed — full scheduling widget embedded on the page.
  Client picks a time, fills in their details, and it syncs to Rhonda's
  Google Calendar automatically. No redirect, no popup.
-->
<div class={`calendly-container ${extraClass}`}>
  {title && (
    <h3 class="font-heading font-bold text-xl text-brand-teal mb-2">{title}</h3>
  )}
  {subtitle && (
    <p class="text-sm text-brand-charcoal/60 mb-6 leading-relaxed">{subtitle}</p>
  )}

  <!-- Calendly inline widget mount point -->
  <div
    id={widgetId}
    class="calendly-inline-widget rounded-[20px] overflow-hidden border border-brand-teal/10 bg-white"
    style="min-width: 320px; height: 650px;"
    data-url={calendlyUrl}
    data-processed="false"
  ></div>
</div>

<script>
  import { CALENDLY } from "@/utils/constants";

  const widgetId = "calendly-inline-widget";

  // Load Calendly's inline widget script once
  const scriptId = "calendly-inline-script";
  if (!document.getElementById(scriptId)) {
    const script = document.createElement("script");
    script.id = scriptId;
    script.src = "https://assets.calendly.com/assets/external/widget.js";
    script.async = true;
    script.onload = initWidget;
    document.head.appendChild(script);
  } else {
    initWidget();
  }

  function initWidget() {
    const Calendly = (window as any).Calendly;
    if (!Calendly) {
      setTimeout(initWidget, 200);
      return;
    }

    const container = document.getElementById(widgetId);
    if (!container || container.dataset.processed === "true") return;

    const url = container.dataset.url;
    if (!url) return;

    Calendly.initInlineWidget({
      url,
      parentElement: container,
      prefill: {},
      utm: {},
    });

    container.dataset.processed = "true";
  }
</script>
