---
// Simple contact form using Web3Forms (free tier, 250/mo).
// Replace the access key with your actual Web3Forms key.
// Alternatively, swap to Formspree by changing the action URL.
const web3formsKey = "YOUR_WEB3FORMS_ACCESS_KEY"; // TODO: replace with actual key
---

<form
  action={`https://api.web3forms.com/submit`}
  method="POST"
  class="space-y-5"
  id="contact-form"
>
  <!-- Web3Forms hidden fields -->
  <input type="hidden" name="access_key" value={web3formsKey} />
  <input type="hidden" name="subject" value="New inquiry from Cosmic Calibrations website" />
  <input type="hidden" name="from_name" value="Cosmic Calibrations Contact Form" />
  <input type="checkbox" name="botcheck" class="hidden" style="display:none;" tabindex="-1" autocomplete="off" />

  <!-- Name -->
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label for="first_name" class="block text-xs font-bold uppercase tracking-[0.12em] text-brand-grey mb-2">
        First Name
      </label>
      <input
        type="text"
        name="first_name"
        id="first_name"
        required
        class="w-full rounded-xl border border-brand-teal/15 px-4 py-3 text-sm text-brand-charcoal bg-white focus:outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal/30 transition-colors"
        placeholder="Your first name"
      />
    </div>
    <div>
      <label for="last_name" class="block text-xs font-bold uppercase tracking-[0.12em] text-brand-grey mb-2">
        Last Name
      </label>
      <input
        type="text"
        name="last_name"
        id="last_name"
        required
        class="w-full rounded-xl border border-brand-teal/15 px-4 py-3 text-sm text-brand-charcoal bg-white focus:outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal/30 transition-colors"
        placeholder="Your last name"
      />
    </div>
  </div>

  <!-- Email -->
  <div>
    <label for="email" class="block text-xs font-bold uppercase tracking-[0.12em] text-brand-grey mb-2">
      Email Address
    </label>
    <input
      type="email"
      name="email"
      id="email"
      required
      class="w-full rounded-xl border border-brand-teal/15 px-4 py-3 text-sm text-brand-charcoal bg-white focus:outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal/30 transition-colors"
      placeholder="you@example.com"
    />
  </div>

  <!-- Concern -->
  <div>
    <label for="concern" class="block text-xs font-bold uppercase tracking-[0.12em] text-brand-grey mb-2">
      I'm interested in
    </label>
    <select
      name="concern"
      id="concern"
      required
      class="w-full rounded-xl border border-brand-teal/15 px-4 py-3 text-sm text-brand-charcoal bg-white focus:outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal/30 transition-colors appearance-none"
      style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"%2394A3B8\" stroke-width=\"2\"><polyline points=\"6 9 12 15 18 9\"/></svg>'); background-repeat: no-repeat; background-position: right 12px center; padding-right: 40px;"
    >
      <option value="" disabled selected>Select an option</option>
      <option value="10-series">The 10-Series Protocol</option>
      <option value="single-session">A Single Session</option>
      <option value="desk-worker">Desk Worker Recovery</option>
      <option value="post-surgical">Post-Surgical Recovery</option>
      <option value="general">General Wellness / Curiosity</option>
      <option value="other">Something Else</option>
    </select>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-xs font-bold uppercase tracking-[0.12em] text-brand-grey mb-2">
      Your Message
    </label>
    <textarea
      name="message"
      id="message"
      rows={4}
      required
      class="w-full rounded-xl border border-brand-teal/15 px-4 py-3 text-sm text-brand-charcoal bg-white focus:outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal/30 transition-colors resize-y"
      placeholder="Tell me a bit about what you're experiencing..."
    ></textarea>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full bg-brand-teal text-white font-semibold px-8 py-3.5 text-sm hover:bg-brand-teal-light shadow-sm hover:shadow-md transition-all duration-200"
    id="submit-btn"
  >
    <span id="submit-text">Send Message</span>
    <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none">
      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.2" />
      <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
    </svg>
  </button>

  <!-- Success message (hidden by default) -->
  <div id="form-success" class="hidden rounded-2xl bg-brand-teal/5 border border-brand-teal/20 p-6 text-center">
    <svg class="w-10 h-10 text-brand-teal mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
      <polyline points="22 4 12 14.01 9 11.01"/>
    </svg>
    <p class="text-brand-teal font-heading font-bold text-lg mb-1">Message sent!</p>
    <p class="text-sm text-brand-charcoal/60">Thank you for reaching out. We'll respond within 24 hours.</p>
  </div>

  <!-- Error message (hidden by default) -->
  <div id="form-error" class="hidden rounded-2xl bg-red-50 border border-red-200 p-4 text-center">
    <p class="text-sm text-red-600">Something went wrong. Please try again or email us directly at rhonda@cosmiccalibrations.com.</p>
  </div>
</form>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const submitText = document.getElementById("submit-text");
  const submitSpinner = document.getElementById("submit-spinner");
  const success = document.getElementById("form-success");
  const error = document.getElementById("form-error");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !submitBtn || !submitText || !submitSpinner || !success || !error) return;

    // Show loading state
    submitBtn.disabled = true;
    submitText.classList.add("hidden");
    submitSpinner?.classList.remove("hidden");
    success.classList.add("hidden");
    error.classList.add("hidden");

    try {
      const formData = new FormData(form);
      const res = await fetch(form.action, {
        method: "POST",
        body: formData,
      });
      const data = await res.json();

      if (data.success) {
        form.reset();
        success.classList.remove("hidden");
      } else {
        error.classList.remove("hidden");
      }
    } catch {
      error.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
      submitText.classList.remove("hidden");
      submitSpinner?.classList.add("hidden");
    }
  });
</script>
