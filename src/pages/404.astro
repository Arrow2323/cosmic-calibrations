---
import Layout from "@/components/base/Layout.astro";
---

<Layout seo={{ title: "Page Not Found", noindex: true }}>
  <section class="min-h-screen flex items-center justify-center px-6 bg-brand-paper pt-16">
    <div class="text-center max-w-md">
      <!-- Cosmic compass illustration -->
      <div class="mb-8 inline-flex items-center justify-center">
        <svg class="w-24 h-24 text-brand-teal/20" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="50" cy="50" r="40" />
          <circle cx="50" cy="50" r="20" />
          <line x1="50" y1="10" x2="50" y2="30" stroke-width="2" />
          <line x1="50" y1="70" x2="50" y2="90" stroke-width="2" />
          <line x1="10" y1="50" x2="30" y2="50" stroke-width="2" />
          <line x1="70" y1="50" x2="90" y2="50" stroke-width="2" />
          <circle cx="50" cy="50" r="3" fill="currentColor" />
        </svg>
      </div>

      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-grey mb-6">404</p>
      <h1 class="text-3xl font-heading font-bold text-brand-teal mb-4">
        This page is out of alignment
      </h1>
      <p class="text-brand-charcoal/60 leading-relaxed mb-8">
        Like a body that's lost its structural balance, this page needs some attention.
        But we can help you find your way back.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-full bg-brand-teal text-white font-semibold px-8 py-4 hover:bg-brand-teal-light shadow-sm transition-all"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Return Home
      </a>
    </div>
  </section>
</Layout>
