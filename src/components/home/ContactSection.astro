---
import { BUSINESS, BOOKING } from "@/utils/constants";
import BookButton from "@/components/ui/BookButton.astro";
import ContactForm from "@/components/ui/ContactForm.astro";
---

<section id="contact" class="py-24 md:py-32 px-6 bg-brand-teal relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.05]"
    style="background-image: radial-gradient(circle, #94A3B8 1px, transparent 1px); background-size: 40px 40px;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="section-label mb-4 text-brand-grey/80">Get in Touch</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">
        Ready to feel different in your body?
      </h2>
      <p class="text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Start with a free 15-minute phone consultation. We'll talk about what you're
        experiencing and whether Structural Integration is the right fit.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Left: Contact Info -->
      <div class="text-white space-y-8">
        <div>
          <h3 class="font-heading font-bold text-xl mb-4 text-brand-grey">Contact</h3>
          <div class="space-y-4 text-white/70 text-sm">
            <p class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-grey shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <a href={`mailto:${BUSINESS.email}`} class="hover:text-white transition-colors">
                {BUSINESS.email}
              </a>
            </p>
            <p class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-grey shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>{BUSINESS.location}</span>
            </p>
          </div>
        </div>

        <div>
          <h3 class="font-heading font-bold text-xl mb-4 text-brand-grey">Hours</h3>
          <div class="space-y-1 text-white/60 text-sm">
            <p>Monday – Friday</p>
            <p>9:00 AM – 6:00 PM</p>
            <p class="text-xs text-white/30 mt-2">By appointment only</p>
          </div>
        </div>

        <div class="pt-6 border-t border-white/10">
          <p class="text-xs text-white/40">
            Your privacy matters. Information submitted through this form is used
            only to respond to your inquiry. We never share or sell your data.
          </p>
        </div>
      </div>

      <!-- Right: Booking + Contact Form tabs -->
      <div>
        <div class="bg-white rounded-[24px] shadow-xl overflow-hidden">
          <!-- Tabs -->
          <div class="flex border-b border-brand-teal/10" role="tablist">
            <button
              id="tab-book"
              role="tab"
              aria-selected="true"
              class="tab-btn flex-1 px-6 py-4 text-sm font-semibold text-brand-teal border-b-2 border-brand-teal bg-brand-teal/5 transition-colors"
              data-tab="book"
            >
              <span class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                Book a Session
              </span>
            </button>
            <button
              id="tab-message"
              role="tab"
              aria-selected="false"
              class="tab-btn flex-1 px-6 py-4 text-sm font-semibold text-brand-grey border-b-2 border-transparent hover:text-brand-teal transition-colors"
              data-tab="message"
            >
              <span class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                Send a Message
              </span>
            </button>
          </div>

          <!-- Tab: Book -->
          <div id="panel-book" class="tab-panel p-8 md:p-10">
            <h3 class="font-heading font-bold text-xl text-brand-teal mb-2">Schedule a free consult</h3>
            <p class="text-sm text-brand-charcoal/60 mb-6 leading-relaxed">
              Choose a time that works for you. Your session is confirmed instantly and
              Rhonda's calendar is updated automatically — no accounts, no registration.
            </p>
            <BookButton label={BOOKING.label} variant="primary" class="w-full justify-center !px-8 !py-4" />
            <p class="text-xs text-brand-charcoal/40 mt-4 text-center">
              Opens Google Calendar in a new tab
            </p>
          </div>

          <!-- Tab: Message -->
          <div id="panel-message" class="tab-panel hidden">
            <div class="p-8">
              <h3 class="font-heading font-bold text-xl text-brand-teal mb-2">Send a message</h3>
              <p class="text-sm text-brand-charcoal/60 mb-6">
                Prefer to reach out directly? Fill out the form below and we'll respond within 24 hours.
              </p>
              <ContactForm />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function switchTab(tabId: string) {
    document.querySelectorAll(".tab-btn").forEach((btn) => {
      const isActive = (btn as HTMLElement).dataset.tab === tabId;
      btn.setAttribute("aria-selected", String(isActive));
      if (isActive) {
        btn.classList.add("text-brand-teal", "border-b-2", "border-brand-teal", "bg-brand-teal/5");
        btn.classList.remove("text-brand-grey", "border-transparent", "hover:text-brand-teal");
      } else {
        btn.classList.add("text-brand-grey", "border-transparent", "hover:text-brand-teal");
        btn.classList.remove("text-brand-teal", "border-b-2", "border-brand-teal", "bg-brand-teal/5");
      }
    });
    document.querySelectorAll(".tab-panel").forEach((panel) => {
      if (panel.id === `panel-${tabId}`) {
        panel.classList.remove("hidden");
      } else {
        panel.classList.add("hidden");
      }
    });
  }
  document.querySelectorAll(".tab-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const tabId = (btn as HTMLElement).dataset.tab;
      if (tabId) switchTab(tabId);
    });
  });
</script>
