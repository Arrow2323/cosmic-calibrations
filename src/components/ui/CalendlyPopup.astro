---
import { CALENDLY } from "@/utils/constants";

export interface Props {
  /** Button label */
  label?: string;
  /** Button variant style */
  variant?: "primary" | "primary-light" | "outline";
  /** Custom class overrides */
  class?: string;
}

const {
  label = "Book a Free Consult",
  variant = "primary",
  class: extraClass = "",
} = Astro.props;

const calendlyUrl = `https://calendly.com/${CALENDLY.username}/${CALENDLY.eventType}`;

const baseClasses = "calendly-popup inline-flex items-center gap-2 font-semibold transition-all duration-200 rounded-full";

const variantClasses = {
  primary:
    "bg-brand-teal text-white hover:bg-brand-teal-light shadow-sm hover:shadow-md",
  "primary-light":
    "bg-white text-brand-teal hover:bg-white/90 shadow-sm",
  outline:
    "border-2 border-brand-teal text-brand-teal hover:bg-brand-teal hover:text-white",
} as const;

const sizeClasses = "px-7 py-3 text-base";
---

<!--
  Calendly Popup Button — opens scheduling widget in a popup overlay.
  Uses Calendly's popup widget. Client selects time → Rhonda's Google
  Calendar updates automatically. No page navigation needed.
-->
<a
  href={calendlyUrl}
  class={`${baseClasses} ${variantClasses[variant]} ${sizeClasses} ${extraClass}`}
  onclick="return false;"
>
  <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
    <line x1="16" y1="2" x2="16" y2="6" />
    <line x1="8" y1="2" x2="8" y2="6" />
    <line x1="3" y1="10" x2="21" y2="10" />
    <polyline points="9 16 11 18 15 14" />
  </svg>
  {label}
</a>

<script>
  import { CALENDLY } from "@/utils/constants";

  const url = `https://calendly.com/${CALENDLY.username}/${CALENDLY.eventType}`;

  // Load Calendly's popup widget script once
  const scriptId = "calendly-popup-script";
  if (!document.getElementById(scriptId)) {
    const script = document.createElement("script");
    script.id = scriptId;
    script.src = "https://assets.calendly.com/assets/external/widget.js";
    script.async = true;
    document.head.appendChild(script);
  }

  // Hook up buttons when Calendly is ready
  function bindCalendly() {
    const Calendly = (window as any).Calendly;
    if (!Calendly) {
      setTimeout(bindCalendly, 200);
      return;
    }

    document.querySelectorAll(".calendly-popup").forEach((el) => {
      el.addEventListener("click", (e) => {
        e.preventDefault();
        Calendly.initPopupWidget({
          url,
          color: `#${CALENDLY.primaryColor}`,
          textColor: "#ffffff",
        });
      });
    });
  }

  bindCalendly();
</script>
